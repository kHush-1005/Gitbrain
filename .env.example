# GitBrain — Environment Variables (template)
# Copy: copy .env.example .env  (Windows)
#       cp .env.example .env    (Mac/Linux)
# Fill in your own keys. Never commit .env to Git.

# GitHub Personal Access Token (optional but recommended)
GITHUB_TOKEN=

# Groq API Key — required for /query chat answers
# Get a free key at: https://console.groq.com
GROQ_API_KEY=

# Groq model
LLM_MODEL=llama-3.1-8b-instant

# Embeddings & vector store
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=data/chroma_db

# Hugging Face token (optional — for private/gated models)
HF_TOKEN=

# RAG retrieval settings
TOP_K_RESULTS=10
SIMILARITY_THRESHOLD=0.15
